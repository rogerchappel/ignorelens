{
  "name": "ignorelens",
  "version": "0.1.0",
  "description": "Local-first ignore and package-boundary auditor for npm, Git, and Docker contexts.",
  "type": "module",
  "main": "./dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc",
    "smoke": "bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "ignore",
    "npmignore",
    "dockerignore",
    "gitignore",
    "packaging",
    "release",
    "cli"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "minimatch": "^10.2.5",
    "picocolors": "^1.1.1"
  },
  "bin": {
    "ignorelens": "./dist/src/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/ignorelens.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/ignorelens/issues"
  },
  "homepage": "https://github.com/rogerchappel/ignorelens#readme"
}
